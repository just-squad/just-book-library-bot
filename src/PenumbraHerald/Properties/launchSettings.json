      "commandName": "Project",
      "dotnetRunMessages": "true",
      "launchBrowser": false,
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Local",
        "ASPNETCORE_HTTP_PORT": "5000",
        "ASPNETCORE_GRPC_PORT": "5002",
        "ASPNETCORE_DEBUG_PORT": "5004",
